{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug app-qt (Windows MSVC 2022)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "${command:cmake.launchTargetDirectory};${env:PATH}"
        }
      ],
      "console": "internalConsole",
      "preLaunchTask": "build",
      "logging": {
        "moduleLoad": false,
        "programOutput": true,
        "exceptions": true
      },
      "visualizerFile": "${workspaceFolder}/.vscode/natvis.xml"
    }
  ]
}
