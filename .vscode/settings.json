{
    "editor.rulers": [
        {"column": 80, "color": "#5385c5"},
        {"column": 100, "color": "#e01447"}
    ],
    "search.exclude": {
        "worktree*/": true,
        "vcpkg/": true
    },
    "files.trimTrailingWhitespace": true,
    "files.encoding": "utf8",

    "terminal.integrated.defaultProfile.windows": "Windows PowerShell",
    "terminal.integrated.defaultProfile.linux": "bash"
}
