{
  "version": 8,
  "configurePresets": [
    {
      "name": "linux-vcpkg-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-vcpkg-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-system-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-system-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-vcpkg",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-system",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-sdk",
      "displayName": "Build with local SDK (.sdk)",
      "description": "Uses pre-built dependencies from `.sdk` dir (vcpkg export)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "VCPKG_MANIFEST_MODE": "OFF"
      },
      "toolchainFile": "${sourceDir}/.sdk/scripts/buildsystems/vcpkg.cmake",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-sdk-release",
      "displayName": "Build with local SDK (.sdk)",
      "description": "Uses pre-built dependencies from `.sdk` dir (vcpkg export)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "VCPKG_MANIFEST_MODE": "OFF"
      },
      "toolchainFile": "${sourceDir}/.sdk/scripts/buildsystems/vcpkg.cmake",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "mac-vcpkg-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "VCPKG_TARGET_TRIPLET": "x64-mac",
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "macOS"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-base",
      "hidden": true,
      "targets": ["all", "appimage-app-qt"]
    },
    {
      "name": "linux-vcpkg-release",
      "inherits": ["linux-base"],
      "configurePreset": "linux-vcpkg-release"
    },
    {
      "name": "linux-system-release",
      "inherits": ["linux-base"],
      "configurePreset": "linux-system-release"
    },
    {
      "name": "linux-sdk-release",
      "inherits": ["linux-base"],
      "configurePreset": "linux-sdk-release"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "windows-sdk-release",
      "configurePreset": "windows-sdk",
      "configuration": "Release"
    },
    {
      "name": "windows-system-release",
      "configurePreset": "windows-system",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "linux-vcpkg-release",
      "configurePreset": "linux-vcpkg-release"
    },
    {
      "name": "linux-system-release",
      "configurePreset": "linux-system-release"
    },
    {
      "name": "linux-sdk-release",
      "configurePreset": "linux-sdk-release"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg"
    },
    {
      "name": "windows-system-release",
      "configurePreset": "windows-system"
