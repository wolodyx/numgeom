      "name": "linux-system-release",
      "configurePreset": "linux-system-release",
      "generators": ["DEB"]
    },
    {
      "name": "linux-sdk-release",
      "configurePreset": "linux-sdk-release"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
