{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-vcpkg-release",
      "toolchainFile": "vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/bld/install"
      },
      "binaryDir": "${sourceDir}/bld"
    },
    {
      "name": "linux-vcpkg-release",
      "toolchainFile": "vcpkg/scripts/buildsystems/vcpkg.cmake",
      "generator": "Ninja",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/bld/${presetName}/install",
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "binaryDir": "${sourceDir}/bld/${presetName}"
    },
    {
      "name": "linux-vcpkg-debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/bld/${presetName}/install",
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "binaryDir": "${sourceDir}/bld/${presetName}"
    },
    {
      "name": "linux-host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "environment": {
        "LD_LIBRARY_PATH": "/usr/lib64"
      },
      "binaryDir": "${sourceDir}/bld/${presetName}"
    }
  ],
  "buildPresets": [
    {
      "name": "linux-vcpkg-release",
      "configurePreset": "linux-vcpkg-release"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg-release"
    }
  ],
  "testPresets": [
    {
      "name": "linux-vcpkg-release",
      "configurePreset": "linux-vcpkg-release"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg-release"
    }
  ],
  "workflowPresets": [
    {
      "name": "ubuntu-ci",
      "steps": [
        {
          "type": "configure",
          "name": "linux-vcpkg-release"
        },
        {
          "type": "build",
          "name": "linux-vcpkg-release"
        },
        {
          "type": "test",
          "name": "linux-vcpkg-release"
        }
      ]
    },
    {
      "name": "windows-ci",
      "steps": [
        {
          "type": "configure",
          "name": "windows-vcpkg-release"
        },
        {
          "type": "build",
          "name": "windows-vcpkg-release"
        },
        {
          "type": "test",
          "name": "windows-vcpkg-release"
        }
      ]
    }
  ]
}

